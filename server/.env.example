PORT=3002
APP_ENV=dev

# PostgreSQL connection string
# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chufangapp?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chufangapp?schema=public"

# JWT secrets
JWT_ADMIN_SECRET="change-me-admin"
