PORT=3002
APP_ENV=dev

# PostgreSQL connection string
# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chufangapp?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chufangapp?schema=public"

# JWT secrets
JWT_ADMIN_SECRET="change-me-admin"
JWT_APP_SECRET="change-me-app"

# CORS
# Use comma-separated origins in production, for example:
# CORS_ORIGIN="https://admin.example.com,https://www.example.com"
# In APP_ENV=dev, localhost/127.0.0.1 Vite ports are also allowed automatically.
CORS_ORIGIN="http://localhost:5176,http://127.0.0.1:5176"

# Local uploads
UPLOAD_DIR="./uploads"
