  navStyle        String     @default("text_tab") @map("nav_style") @db.VarChar(32)
  activeStyle     String     @default("underline") @map("active_style") @db.VarChar(32)
  layoutMode      String     @default("fixed") @map("layout_mode") @db.VarChar(32)
  textColor       String     @default("#666666") @map("text_color") @db.VarChar(16)
  activeTextColor String     @default("#7A8B6F") @map("active_text_color") @db.VarChar(16)
  showDivider     Boolean    @default(true) @map("show_divider")
  tabGap          String     @default("medium") @map("tab_gap") @db.VarChar(16)
  reserveSpace    Boolean    @default(false) @map("reserve_space")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  nav             HomeTopNav @relation(fields: [navId], references: [id], onDelete: Cascade)

  @@map("home_top_nav_styles")
}

model ContentModule {
  id            Int        @id @default(autoincrement())
  navId         Int        @map("nav_id")
  title         String     @db.VarChar(80)
  subtitle      String?    @db.VarChar(160)
  displayStyle  String     @map("display_style") @db.VarChar(40)
  contentType   String     @map("content_type") @db.VarChar(20)
  contentSource String     @map("content_source") @db.VarChar(20)
  displayCount  Int        @default(6) @map("display_count")
  showMore      Boolean    @default(false) @map("show_more")
  showTitle     Boolean    @default(true) @map("show_title")
  moreLink      String?    @map("more_link") @db.VarChar(255)
  sortOrder     Int        @default(1) @map("sort_order")
  status        String     @default("ENABLED") @db.VarChar(20)
  items         Json?
  categoryId    Int?       @map("category_id")
  tagId         Int?       @map("tag_id")

  nav           HomeTopNav @relation(fields: [navId], references: [id], onDelete: Cascade)

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([navId, status, sortOrder])
  @@map("content_modules")
}

model HomeTopNavContentRule {
  id                  Int        @id @default(autoincrement())
  navId               Int        @unique @map("nav_id")
  sourceType          String     @default("category") @map("source_type") @db.VarChar(32)
  difficultyFilter    String?    @default("all") @map("difficulty_filter") @db.VarChar(32)
  durationFilter      String?    @default("all") @map("duration_filter") @db.VarChar(32)
  cookingMethodFilter String?    @default("all") @map("cooking_method_filter") @db.VarChar(32)
  displayCount        Int        @default(6) @map("display_count")
  sortRule            String     @default("comprehensive") @map("sort_rule") @db.VarChar(32)
  moreButtonText      String     @default("查看更多") @map("more_button_text") @db.VarChar(20)
  jumpRule            String     @default("nav_content_list") @map("jump_rule") @db.VarChar(64)
  recommendStartAt    DateTime?  @map("recommend_start_at")
  recommendEndAt      DateTime?  @map("recommend_end_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  nav                 HomeTopNav @relation(fields: [navId], references: [id], onDelete: Cascade)

  @@map("home_top_nav_content_rules")
}
