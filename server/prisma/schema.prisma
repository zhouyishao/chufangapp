generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  ACTIVE
  DISABLED
}

enum AuditStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum SourceType {
  ADMIN
  USER
  IMPORT
  SYSTEM
}

enum CategoryType {
  RECIPE
  INGREDIENT
  SEASONING
  FRUIT
  COCKTAIL
  BEVERAGE
}

enum TargetType {
  NONE
  URL
  RECIPE
  INGREDIENT
  CATEGORY
  MENU
  BEVERAGE
  TOPIC
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum TagScope {
  RECIPE
  INGREDIENT
  SCENE
  TASTE
  METHOD
  CROWD
}

enum FamilyMemberRole {
  CREATOR
  ADMIN
  MEMBER
}

enum FamilyJoinMethod {
  SCAN_QR
  MANUAL_INVITE
  INVITE_LINK
  ADMIN_CREATE
}

enum FamilyMemberStatus {
  ACTIVE
  LEFT
  REMOVED
}

enum FamilyInviteMethod {
  QR_CODE
  LINK
}

enum FamilyInviteStatus {
  JOINED
  PENDING
  EXPIRED
  REVOKED
}

enum BannerStatus {
  DRAFT
  ENABLED
  DISABLED
}

model User {
  id            Int           @id @default(autoincrement())
  bizId         String?       @unique @map("biz_id") @db.VarChar(64)
  code          String?       @unique @db.VarChar(32)
  phone         String?       @unique @db.VarChar(32)
  openid        String?       @unique @db.VarChar(80)
  nickname      String?       @db.VarChar(60)
  avatar        String?       @db.VarChar(255)
  gender        String?       @db.VarChar(16)

  recipes       Recipe[]      @relation("UserRecipes")
  favorites     Favorite[]
  viewHistories ViewHistory[]
  comments      Comment[]
  posts         Post[]
  ownedFamilies Family[]      @relation("FamilyOwner")
  familyMembers FamilyMember[]
  sentFamilyInvites FamilyInvite[] @relation("FamilyInviter")
  acceptedFamilyInvites FamilyInvite[] @relation("FamilyInvitee")

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")
  status        RecordStatus  @default(ACTIVE) @map("status")
  sort          Int           @default(0) @map("sort")
  sortOrder     Int           @default(0) @map("sort_order")
  isDeleted     Boolean       @default(false) @map("is_deleted")
  isPublish     Boolean       @default(false) @map("is_publish")
  isRecommend   Boolean       @default(false) @map("is_recommend")
  sourceType    SourceType    @default(USER) @map("source_type")
  sourceId      Int?          @map("source_id")
  auditStatus   AuditStatus   @default(APPROVED) @map("audit_status")
  createdBy     Int?          @map("created_by")
  updatedBy     Int?          @map("updated_by")

  @@map("users")
}

model Family {
  id             Int          @id @default(autoincrement())
  bizId          String?      @unique @map("biz_id") @db.VarChar(64)
  code           String?      @unique @db.VarChar(32)
  name           String       @db.VarChar(80)
  avatar         String?      @db.VarChar(255)
  city           String?      @db.VarChar(40)
  district       String?      @db.VarChar(40)
  ownerId        Int?         @map("owner_id")
  memberLimit    Int          @default(8) @map("member_limit")
  activeAt       DateTime?    @map("active_at")
  description    String?      @db.VarChar(255)

  owner          User?        @relation("FamilyOwner", fields: [ownerId], references: [id])
  members        FamilyMember[]
  invites        FamilyInvite[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  status         RecordStatus @default(ACTIVE) @map("status")
  sort           Int          @default(0) @map("sort")
  sortOrder      Int          @default(0) @map("sort_order")
  isDeleted      Boolean      @default(false) @map("is_deleted")
  isPublish      Boolean      @default(false) @map("is_publish")
  isRecommend    Boolean      @default(false) @map("is_recommend")
  sourceType     SourceType   @default(USER) @map("source_type")
  sourceId       Int?         @map("source_id")
  auditStatus    AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy      Int?         @map("created_by")
  updatedBy      Int?         @map("updated_by")

  @@index([ownerId])
  @@map("families")
}

model FamilyMember {
  id           Int                @id @default(autoincrement())
  familyId     Int                @map("family_id")
  userId       Int                @map("user_id")
  role         FamilyMemberRole   @default(MEMBER)
  joinMethod   FamilyJoinMethod   @default(SCAN_QR) @map("join_method")
  joinedAt     DateTime           @default(now()) @map("joined_at")
  leftAt       DateTime?          @map("left_at")
  memberStatus FamilyMemberStatus @default(ACTIVE) @map("member_status")
  remark       String?            @db.VarChar(255)

  family       Family             @relation(fields: [familyId], references: [id])
  user         User               @relation(fields: [userId], references: [id])

  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  deletedAt    DateTime?          @map("deleted_at")
  status       RecordStatus       @default(ACTIVE) @map("status")
  sort         Int                @default(0) @map("sort")
  isPublish    Boolean            @default(false) @map("is_publish")
  isRecommend  Boolean            @default(false) @map("is_recommend")
  sourceType   SourceType         @default(USER) @map("source_type")
  sourceId     Int?               @map("source_id")
  auditStatus  AuditStatus        @default(APPROVED) @map("audit_status")
  createdBy    Int?               @map("created_by")
  updatedBy    Int?               @map("updated_by")

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
  @@map("family_members")
}

model FamilyInvite {
  id           Int                @id @default(autoincrement())
  bizId        String?            @unique @map("biz_id") @db.VarChar(64)
  code         String?            @unique @db.VarChar(32)
  familyId     Int                @map("family_id")
  inviterId    Int?               @map("inviter_id")
  inviteeId    Int?               @map("invitee_id")
  inviteName   String             @map("invite_name") @db.VarChar(120)
  inviteMethod FamilyInviteMethod @default(QR_CODE) @map("invite_method")
  inviteType   String             @default("家庭邀请") @map("invite_type") @db.VarChar(40)
  token        String?            @unique @db.VarChar(64)
  url          String?            @db.VarChar(255)
  inviteStatus FamilyInviteStatus @default(PENDING) @map("invite_status")
  joinedAt     DateTime?          @map("joined_at")
  expiresAt    DateTime?          @map("expires_at")
  revokedAt    DateTime?          @map("revoked_at")

  family       Family             @relation(fields: [familyId], references: [id])
  inviter      User?              @relation("FamilyInviter", fields: [inviterId], references: [id])
  invitee      User?              @relation("FamilyInvitee", fields: [inviteeId], references: [id])

  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  deletedAt    DateTime?          @map("deleted_at")
  status       RecordStatus       @default(ACTIVE) @map("status")
  sort         Int                @default(0) @map("sort")
  isPublish    Boolean            @default(false) @map("is_publish")
  isRecommend  Boolean            @default(false) @map("is_recommend")
  sourceType   SourceType         @default(USER) @map("source_type")
  sourceId     Int?               @map("source_id")
  auditStatus  AuditStatus        @default(APPROVED) @map("audit_status")
  createdBy    Int?               @map("created_by")
  updatedBy    Int?               @map("updated_by")

  @@index([familyId])
  @@index([inviterId])
  @@index([inviteeId])
  @@map("family_invites")
}

model Admin {
  id           Int          @id @default(autoincrement())
  username     String       @unique @db.VarChar(32)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  nickname     String?      @db.VarChar(32)

  roles        AdminRole[]

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  isPublish    Boolean      @default(false) @map("is_publish")
  isRecommend  Boolean      @default(false) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

  @@map("admins")
}

model Role {
  id           Int            @id @default(autoincrement())
  name         String         @unique @db.VarChar(50)
  description  String?        @db.VarChar(255)

  admins       AdminRole[]
  permissions  RolePermission[]

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")
  status       RecordStatus   @default(ACTIVE) @map("status")
  sort         Int            @default(0) @map("sort")
  isPublish    Boolean        @default(false) @map("is_publish")
  isRecommend  Boolean        @default(false) @map("is_recommend")
  sourceType   SourceType     @default(ADMIN) @map("source_type")
  sourceId     Int?           @map("source_id")
  auditStatus  AuditStatus    @default(APPROVED) @map("audit_status")
  createdBy    Int?           @map("created_by")
  updatedBy    Int?           @map("updated_by")

  @@map("roles")
}

model Permission {
  id           Int            @id @default(autoincrement())
  key          String         @unique @db.VarChar(80)
  name         String         @db.VarChar(80)
  description  String?        @db.VarChar(255)

  roles        RolePermission[]

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")
  status       RecordStatus   @default(ACTIVE) @map("status")
  sort         Int            @default(0) @map("sort")
  isPublish    Boolean        @default(false) @map("is_publish")
  isRecommend  Boolean        @default(false) @map("is_recommend")
  sourceType   SourceType     @default(ADMIN) @map("source_type")
  sourceId     Int?           @map("source_id")
  auditStatus  AuditStatus    @default(APPROVED) @map("audit_status")
  createdBy    Int?           @map("created_by")
  updatedBy    Int?           @map("updated_by")

  @@map("permissions")
}

model AdminRole {
  id           Int          @id @default(autoincrement())
  adminId      Int          @map("admin_id")
  roleId       Int          @map("role_id")

  admin        Admin        @relation(fields: [adminId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  isPublish    Boolean      @default(false) @map("is_publish")
  isRecommend  Boolean      @default(false) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

  @@unique([adminId, roleId])
  @@map("admin_roles")
}

model RolePermission {
  id           Int          @id @default(autoincrement())
  roleId       Int          @map("role_id")
  permissionId Int          @map("permission_id")

  role         Role         @relation(fields: [roleId], references: [id])
  permission   Permission   @relation(fields: [permissionId], references: [id])

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  isPublish    Boolean      @default(false) @map("is_publish")
  isRecommend  Boolean      @default(false) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Category {
  id           Int          @id @default(autoincrement())
  bizId        String?      @unique @map("biz_id") @db.VarChar(64)
  code         String?      @unique @db.VarChar(32)
  type         CategoryType @map("type")
  name         String       @db.VarChar(80)

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  sortOrder    Int          @default(0) @map("sort_order")
  isDeleted    Boolean      @default(false) @map("is_deleted")
  isPublish    Boolean      @default(false) @map("is_publish")
  isRecommend  Boolean      @default(false) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

  ingredients  Ingredient[]
  recipes      Recipe[]
  recommendations Recommendation[]
  beverages    Beverage[]

  @@unique([type, name])
  @@map("categories")
}

model Ingredient {
  id             Int          @id @default(autoincrement())
  bizId          String?      @unique @map("biz_id") @db.VarChar(64)
  code           String?      @unique @db.VarChar(32)
  name           String       @db.VarChar(80)
  cover          String?      @db.VarChar(255)
  categoryId     Int?         @map("category_id")
  seasonMonth    String?      @map("season_month") @db.VarChar(64)
  nutrition      String?      @db.Text
  selectionTips  String?      @map("selection_tips") @db.Text
  storageMethod  String?      @map("storage_method") @db.Text
  taboo          String?      @db.Text
  detailImages   Json?        @map("detail_images")
  selectionMedia String?      @map("selection_media") @db.VarChar(255)
  relatedRecipes Json?        @map("related_recipes")
  currentPrice   Float?       @map("current_price")
  priceUnit      String?      @map("price_unit") @db.VarChar(20)
  priceSource    String?      @map("price_source") @db.VarChar(80)
  priceDate      DateTime?    @map("price_date")

  category       Category?    @relation(fields: [categoryId], references: [id])
  ingredientTags IngredientTag[]
  recipeIngredients RecipeIngredient[]
  tips           IngredientTip[]
  seasonalFoods  SeasonalFood[]
  recommendations Recommendation[]
  favorites      Favorite[]
  viewHistories  ViewHistory[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  status         RecordStatus @default(ACTIVE) @map("status")
  sort           Int          @default(0) @map("sort")
  sortOrder      Int          @default(0) @map("sort_order")
  isDeleted      Boolean      @default(false) @map("is_deleted")
  isPublish      Boolean      @default(false) @map("is_publish")
  isRecommend    Boolean      @default(false) @map("is_recommend")
  sourceType     SourceType   @default(ADMIN) @map("source_type")
  sourceId       Int?         @map("source_id")
  auditStatus    AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy      Int?         @map("created_by")
  updatedBy      Int?         @map("updated_by")

  @@unique([name])
  @@index([categoryId])
  @@map("ingredients")
}

model IngredientTip {
  id           Int          @id @default(autoincrement())
  ingredientId Int          @map("ingredient_id")
  title        String       @db.VarChar(120)
  content      String       @db.Text

  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id])

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  isPublish    Boolean      @default(true) @map("is_publish")
  isRecommend  Boolean      @default(false) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

  @@index([ingredientId])
  @@map("ingredient_tips")
}

model Cuisine {
  id           Int          @id @default(autoincrement())
  name         String       @unique @db.VarChar(80)
  cover        String?      @db.VarChar(255)
  description  String?      @db.Text

  recipes      Recipe[]

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  isPublish    Boolean      @default(true) @map("is_publish")
  isRecommend  Boolean      @default(false) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

  @@map("cuisines")
}

model Recipe {
  id             Int          @id @default(autoincrement())
  bizId          String?      @unique @map("biz_id") @db.VarChar(64)
  code           String?      @unique @db.VarChar(32)
  title          String       @db.VarChar(120)
  subtitle       String?      @db.VarChar(255)
  cover          String?      @db.VarChar(255)
  images         Json?        @map("images")
  video          String?      @db.VarChar(255)
  visibility     String?      @db.VarChar(32)
  description    String?      @db.Text

  categoryId     Int?         @map("category_id")
  cuisineId      Int?         @map("cuisine_id")
  difficulty     String?      @db.VarChar(20)
  cookTime       Int?         @map("cook_time")
  servings       Int?
  calories       Int?
  taste          String?      @db.VarChar(50)
  scene          String?      @db.VarChar(50)
  tips           String?      @db.Text

  authorId       Int?         @map("author_id")
  rejectReason   String?      @map("reject_reason") @db.Text
  importSourceType String?    @map("source_type_external") @db.VarChar(80)
  sourceName     String?      @map("source_name") @db.VarChar(120)
  sourceRecipeId String?      @map("source_recipe_id") @db.VarChar(120)
  sourceUrl      String?      @map("source_url") @db.VarChar(255)
  isDraft        Boolean      @default(true) @map("is_draft")
  viewCount      Int          @default(0) @map("view_count")
  favoriteCount  Int          @default(0) @map("favorite_count")
  commentCount   Int          @default(0) @map("comment_count")

  category       Category?    @relation(fields: [categoryId], references: [id])
  cuisine        Cuisine?     @relation(fields: [cuisineId], references: [id])
  author         User?        @relation("UserRecipes", fields: [authorId], references: [id])
  steps          RecipeStep[]
  ingredients    RecipeIngredient[]
  menuRecipes    MenuRecipe[]
  recipeTags     RecipeTag[]
  recommendations Recommendation[]
  banners        Banner[]
  favorites      Favorite[]
  viewHistories  ViewHistory[]
  comments       Comment[]
  posts          Post[]
  beverages      RecipeBeverage[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  status         RecordStatus @default(ACTIVE) @map("status")
  sort           Int          @default(0) @map("sort")
  sortOrder      Int          @default(0) @map("sort_order")
  isDeleted      Boolean      @default(false) @map("is_deleted")
  isPublish      Boolean      @default(false) @map("is_publish")
  isRecommend    Boolean      @default(false) @map("is_recommend")
  sourceType     SourceType   @default(ADMIN) @map("source_type")
  sourceId       Int?         @map("source_id")
  auditStatus    AuditStatus  @default(DRAFT) @map("audit_status")
  createdBy      Int?         @map("created_by")
  updatedBy      Int?         @map("updated_by")

  @@unique([importSourceType, sourceName, sourceRecipeId])
  @@map("recipes")
}

model SeasonalFood {
  id           Int          @id @default(autoincrement())
  ingredientId Int?         @map("ingredient_id")
  name         String       @db.VarChar(80)
  month        Int
  cover        String?      @db.VarChar(255)
  reason       String?      @db.Text

  ingredient   Ingredient?  @relation(fields: [ingredientId], references: [id])

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  isPublish    Boolean      @default(true) @map("is_publish")
  isRecommend  Boolean      @default(false) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

  @@index([ingredientId])
  @@index([month])
  @@map("seasonal_foods")
}

model Recommendation {
  id           Int          @id @default(autoincrement())
  bizId        String?      @unique @map("biz_id") @db.VarChar(64)
  code         String?      @unique @db.VarChar(32)
  title        String       @db.VarChar(120)
  description  String?      @db.Text
  cover        String?      @db.VarChar(255)
  targetType   TargetType   @default(RECIPE) @map("target_type")
  targetUrl    String?      @map("target_url") @db.VarChar(255)
  recipeId     Int?         @map("recipe_id")
  ingredientId Int?         @map("ingredient_id")
  categoryId   Int?         @map("category_id")
  startAt      DateTime?    @map("start_at")
  endAt        DateTime?    @map("end_at")

  recipe       Recipe?      @relation(fields: [recipeId], references: [id])
  ingredient   Ingredient?  @relation(fields: [ingredientId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  status       RecordStatus @default(ACTIVE) @map("status")
  sort         Int          @default(0) @map("sort")
  sortOrder    Int          @default(0) @map("sort_order")
  isDeleted    Boolean      @default(false) @map("is_deleted")
  isPublish    Boolean      @default(true) @map("is_publish")
  isRecommend  Boolean      @default(true) @map("is_recommend")
  sourceType   SourceType   @default(ADMIN) @map("source_type")
  sourceId     Int?         @map("source_id")
  auditStatus  AuditStatus  @default(APPROVED) @map("audit_status")
  createdBy    Int?         @map("created_by")
  updatedBy    Int?         @map("updated_by")

